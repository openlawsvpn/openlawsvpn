<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="openlawsvpn — SAML Callback PoC"
            android:textAppearance="?attr/textAppearanceTitleMedium"
            android:paddingBottom="4dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Tests whether Chrome Custom Tabs allows\nthe AWS SSO SPA to POST SAMLResponse to 127.0.0.1:35001"
            android:textAppearance="?attr/textAppearanceBodySmall"
            android:paddingBottom="16dp" />

        <!-- ── Step 1: ACS server ── -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Step 1 — ACS server"
            android:textAppearance="?attr/textAppearanceLabelLarge"
            android:paddingBottom="4dp" />

        <Button
            android:id="@+id/btnToggleServer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Start ACS Server (:35001)"
            android:layout_marginBottom="16dp" />

        <!-- ── Step 2a: Local test (no AWS) ── -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Step 2a — Local test (no AWS credentials needed)"
            android:textAppearance="?attr/textAppearanceLabelLarge"
            android:paddingBottom="4dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Opens http://127.0.0.1:35001/test — a self-hosted form that POSTs a fake token back to the server (HTTP→HTTP). Should always work."
            android:textAppearance="?attr/textAppearanceBodySmall"
            android:paddingBottom="8dp" />

        <Button
            android:id="@+id/btnTestLocal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Test Local Callback"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_marginBottom="16dp" />

        <!-- ── Step 2b: Real SAML URL ── -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Step 2b — Real SAML URL (from Linux CLI Phase 1)"
            android:textAppearance="?attr/textAppearanceLabelLarge"
            android:paddingBottom="4dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Run the Linux CLI, copy the printed SAML URL, paste it below. This tests the HTTPS→HTTP mixed-content form POST."
            android:textAppearance="?attr/textAppearanceBodySmall"
            android:paddingBottom="8dp" />

        <EditText
            android:id="@+id/etSamlUrl"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Paste SAML URL here (https://portal.sso.…)"
            android:inputType="textUri|textMultiLine"
            android:minLines="3"
            android:maxLines="5"
            android:layout_marginBottom="8dp" />

        <Button
            android:id="@+id/btnOpenSaml"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Open in Chrome Custom Tabs"
            android:layout_marginBottom="16dp" />

        <!-- ── Log ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingBottom="4dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Log"
                android:textAppearance="?attr/textAppearanceLabelLarge" />

            <Button
                android:id="@+id/btnClear"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Clear"
                style="@style/Widget.Material3.Button.TextButton" />

        </LinearLayout>

        <TextView
            android:id="@+id/tvLog"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="monospace"
            android:textSize="11sp"
            android:background="#F5F5F5"
            android:padding="8dp"
            android:layout_marginBottom="16dp" />

        <!-- ── Captured token ── -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Captured SAMLResponse"
            android:textAppearance="?attr/textAppearanceLabelLarge"
            android:paddingBottom="4dp" />

        <TextView
            android:id="@+id/tvToken"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="SAMLResponse will appear here after successful capture"
            android:fontFamily="monospace"
            android:textSize="10sp"
            android:background="#E8F5E9"
            android:padding="8dp"
            android:layout_marginBottom="32dp" />

    </LinearLayout>

</ScrollView>
